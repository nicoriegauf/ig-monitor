# Discord Bot Configuration
DISCORD_TOKEN=your_discord_bot_token_here

# Allowed User IDs (comma-separated, no spaces)
ALLOWED_USER_IDS=1234567890,0987654321,1122334455

# Bot Settings
CHECK_INTERVAL=90000

# Proxy Rotation (optional aber empfohlen um Instagram Rate-Limits zu vermeiden)
# Format: http://user:pass@host:port  — mehrere mit Komma trennen
# Beispiel Webshare: PROXY_URLS=http://user:pass@proxy.webshare.io:80
# Beispiel mehrere:  PROXY_URLS=http://u:p@host1:80,http://u:p@host2:80
PROXY_URLS=
